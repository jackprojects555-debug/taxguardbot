BOT_TOKEN=           # Telegram bot token — required, bot will not start without this
ADMIN_TOKEN=         # Long random secret for admin API Bearer auth — required for admin server
ADMIN_HOST=127.0.0.1 # Optional — admin server bind address (default: 127.0.0.1)
ADMIN_PORT=8080      # Optional — admin server bind port (default: 8080)
DATABASE_URL=        # PostgreSQL connection string (e.g. Neon). If unset, SQLite is used locally.
